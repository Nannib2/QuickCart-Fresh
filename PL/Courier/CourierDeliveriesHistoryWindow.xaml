<Window x:Class="PL.Courier.CourierDeliveriesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Courier"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d" 
        WindowState="Maximized"
        Title="My Delivery History - QuickCart Fresh" Height="800" Width="1100" 
        Loaded="CourierDeliveriesHistoryWindow_Loaded" Closed="CourierDeliveriesHistoryWindow_Closed">

    <Window.Resources>
        <CollectionViewSource x:Key="OrderRequirementsCollection" Source="{Binding Source={StaticResource OrderRequirementsCollectionKey}}"/>
        <CollectionViewSource x:Key="ClosedDeliveryInListPropertiesCollection" Source="{Binding Source={StaticResource ClosedDeliveryInListPropertiesCollectionKey}}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Grid Width="45" Height="45">
                        <Ellipse Fill="#81C784"/>
                        <TextBlock Text="📜" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="My Delivery History" FontWeight="Bold" FontSize="18" Foreground="#1B5E20"/>
                        <TextBlock Text="Archive of closed orders" FontSize="12" Foreground="#666666"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="QuickCart Fresh" VerticalAlignment="Center" FontSize="18" FontWeight="ExtraBold" Foreground="#1B5E20" Margin="0,0,15,0"/>
                    <Button Click="btnBackCourierWindow_Click" 
                      Style="{StaticResource LogoButtonStyle}" Margin="0,0,15,0">
                        <Image Source="/Images/FinalSystemLogo.png" 
         Height="50" 
         VerticalAlignment="Center"
         RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,30,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="🔍" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Label Content="Filter by Requirements:" FontWeight="SemiBold" Foreground="#1B5E20"/>
                    </StackPanel>
                    
                    <ComboBox Width="180"
                        MinHeight="40"
                        Padding="8,3"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Left"
                        SelectionChanged="ComboBox_FilterSelectionChanged"
                        SelectedValue="{Binding SelectedFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- View All --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- View All --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource OrderRequirementsCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="🔃" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Label Content="Sort Deliveries By:" FontWeight="SemiBold" Foreground="#1B5E20"/>
                    </StackPanel>

                    <ComboBox Width="200" Height="40" VerticalContentAlignment="Center"
                      SelectedItem="{Binding SelectedSort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="ComboBox_SortSelectionChanged"
                       ItemsSource="{Binding ClosedDeliveryInList}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" ClipToBounds="True" Background="#FEFEFA" >
            <DataGrid ItemsSource="{Binding ClosedDeliveries}"
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      GridLinesVisibility="Horizontal" 
                      HorizontalGridLinesBrush="#EEEEEE"
                      RowHeight="45"
                      Background="Transparent" 
                      BorderThickness="0">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#81C784"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="🔢 Order ID" Binding="{Binding OrderId}" Width="*"/>

                    <DataGridTextColumn Header="📦 Type" Binding="{Binding OrderType}" Width="*"/>

                    <DataGridTextColumn Header="🚲 Delivery Type" Binding="{Binding DeliveryType}" Width="*"/>

                    <DataGridTextColumn Header="📍 Destination" Binding="{Binding FullAddress}" Width="2*"/>

                    <DataGridTextColumn Header="🛣️ Distance" Binding="{Binding ActualDistance, StringFormat={}{0:N2} km}" Width="120"/>

                    <DataGridTextColumn Header="⏱️ Duration" Binding="{Binding TotalCompletionTime}" Width="120"/>

                    <DataGridTemplateColumn Header="🏁 Completion Status" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{Binding DeliveryCompletionType, Converter={StaticResource DeliveryCompletionToColorConverterKey}}" CornerRadius="15" Padding="10,4" Margin="5" HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DeliveryCompletionType, Converter={StaticResource DeliveryCompletionToIconConverterKey}}" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10"/>
                                        <TextBlock Text="{Binding DeliveryCompletionType}" 
                                                 Foreground="#212121" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>