<Window x:Class="PL.Courier.CourierListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:PL.Courier"
        xmlns:converters="clr-namespace:PL.Converters"
        WindowState="Maximized"
        mc:Ignorable="d"
        
        Title="Courier List - Management System" Height="750" Width="1100" 
        Loaded="CourierInListWindow_Loaded" Closed="CourierInListWindow_Closed">

    <Window.Resources>
        <CollectionViewSource x:Key="CourierInListPropertiesCollection" Source="{Binding Source={StaticResource CourierInListPropertiesCollectionKey}}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Grid Width="45" Height="45">
                        <Ellipse Fill="#FFAB91"/>
                        <TextBlock Text="👤" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Manager" FontWeight="Bold" FontSize="16"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="QuickCart Fresh" VerticalAlignment="Center" FontSize="18" FontWeight="ExtraBold" Foreground="#1B5E20" Margin="0,0,10,0"/>
                    <Button Command="{Binding BackCommand}"
                     Style="{StaticResource LogoButtonStyle}" Margin="0,0,15,0">
                        <Image Source="/Images/FinalSystemLogo.png" 
                            Height="50" 
                            VerticalAlignment="Center"
                            RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                    <TextBlock Text="Sort by:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" Foreground="#1B5E20"/>

                    <ComboBox Width="180"
                              MinHeight="36"
                              Padding="8,3"
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Left"
                              SelectedValue="{Binding SelectedPropForSort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- Default --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- Default --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource CourierInListPropertiesCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,25,0">
                    <TextBlock Text="Filter by:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" Foreground="#1B5E20"/>

                    <ComboBox Width="180"
                              MinHeight="36"
                              Padding="8,3"
                              VerticalContentAlignment="Center"
                              HorizontalContentAlignment="Left"
                              SelectedValue="{Binding SelectedPropForFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- View All --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- View All --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource CourierInListPropertiesCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <Grid>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding SelectedPropForFilter, Converter={StaticResource FilterToVisibilityConverterKey}, ConverterParameter=DeliveryType}">
                        <TextBlock Text="Method:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" Foreground="#1B5E20"/>
                        <ComboBox Width="180"
                                  MinHeight="36"
                                  Padding="8,3"
                                  VerticalContentAlignment="Center"
                                  HorizontalContentAlignment="Left"
                                  ItemsSource="{Binding Source={StaticResource DeliveryTypeMethodsCollectionKey}}" SelectedValue="{Binding Path=DeliveryTypeMethod, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding SelectedPropForFilter, Converter={StaticResource FilterToVisibilityConverterKey}, ConverterParameter=IsActive}">
                        <TextBlock Text="Status:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,8,0" Foreground="#1B5E20"/>
                        <ComboBox Width="180"
                                  MinHeight="36"
                                  Padding="8,3"
                                  VerticalContentAlignment="Center"
                                  HorizontalContentAlignment="Left"
                                  ItemsSource="{Binding BoolOptions}" SelectedValue="{Binding Path=IsActiveFilter, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>
            </WrapPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Background="#FEFEFA" ClipToBounds="True">
            <DataGrid ItemsSource="{Binding Path=CourierList}"
              SelectedItem="{Binding SelectedCourier}"
              MouseDoubleClick="DataGrid_MouseDoubleClick"
              IsReadOnly="True" AutoGenerateColumns="False" 
              EnableRowVirtualization="True"
              RowDetailsVisibilityMode="VisibleWhenSelected"
              HeadersVisibility="Column" 
              ColumnWidth="*" 
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Stretch"
              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
              Background="Transparent" BorderThickness="0" MinRowHeight="40" >

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#81C784"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Id}" Header="ID" Width="*"/>

                    <DataGridTextColumn Binding="{Binding NameCourier}" Header="Name" Width="*"/>

                    <DataGridTextColumn Binding="{Binding DeliveryType}" Header="Delivery Type" Width="*"/>

                    <DataGridTemplateColumn Header="Active" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsEnabled="False" IsChecked="{Binding Path=IsActive}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Start Date" Width="*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="WorkStartTime" StringFormat="dd/MM/yyyy"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>

                    <DataGridTextColumn Binding="{Binding OnTimeDeliveries}" Header="On-Time" Width="*"/>
                    <DataGridTextColumn Binding="{Binding LateDeliveries}" Header="Late" Width="*"/>

                    <DataGridTextColumn Binding="{Binding ActiveDeliveryId}" Header="Active Delivery ID" Width="*"/>

                    <DataGridTemplateColumn Header="Action" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Delete"
                                  Visibility="{Binding  Converter={StaticResource CourierDeleteAbleToVisibilityConverterKey}}"
                                    Command="{Binding DataContext.DeleteCourierCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SmallActionButtonStyle}" />
                                  
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Button Grid.Row="3"
         Content="+ New Courier"
         Command="{Binding AddCourierCommand}"
         HorizontalAlignment="Right"
         Margin="0,15,0,10"
         Style="{StaticResource MainActionButtonStyle}"
         Width="160"
         Height="40"/>
    </Grid>
</Window>