<Window x:Class="PL.Courier.CourierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Courier"
        xmlns:converters="clr-namespace:PL.Converters"
        xmlns:SmartInputValidator="clr-namespace:PL"
        mc:Ignorable="d"
        WindowState="Maximized"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Title="CourierWindow" Height="450" Width="800"  Loaded="CourierWindow_Loaded" Closed="CourierWindow_Closed">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <Grid>
                <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center">

                    <Grid Width="45" Height="45">
                        <Ellipse Fill="#FFAB91"/>
                        <TextBlock Text="👤"
                             Foreground="White"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="20"/>
                    </Grid>

                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Manager" FontWeight="Bold" FontSize="18"/>
                        <TextBlock Text="{Binding ButtonText}" FontSize="12" Foreground="#666666"/>
                    </StackPanel>
                    <TextBlock Text="⚠️ Cannot update Activity and Delivery Type due to active order"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Foreground="#D32F2F"
                         FontWeight="SemiBold"
                         FontSize="14"
                         Visibility="{Binding CurrentCourier.OrderInProgress, Converter={StaticResource NotNullToVisibilityConverterKey}}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">

                    <TextBlock Text="QuickCart Fresh"
                         VerticalAlignment="Center"
                         FontSize="18"
                         FontWeight="ExtraBold"
                         Foreground="#1B5E20"
                         Margin="0,0,10,0"/>

                    <Button Click="btnBackMainWindow_Click" 
                Style="{StaticResource LogoButtonStyle}" Margin="0,0,15,0">
                        <Image Source="/Images/FinalSystemLogo.png" 
                      Height="50" 
                      VerticalAlignment="Center"
                      RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>

        <Border Grid.Row="1"  Style="{StaticResource CardBorderStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Courier details:" FontSize="22" FontWeight="Bold" Foreground="#1B5E20" Margin="0,0,0,20"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="0.6*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="🆔 Courier ID:" />
                        <TextBox Grid.Row="0" Grid.Column="1" 
                              IsReadOnly="{Binding IsUpdateMode}">

                            <TextBox.Text>
                                <Binding Path="CurrentCourier.Id" 
                                    UpdateSourceTrigger="PropertyChanged">

                                    <Binding.ValidationRules>
                                        <SmartInputValidator:SmartInputValidator Type="Integer"/>
                                    </Binding.ValidationRules>

                                </Binding>
                            </TextBox.Text>

                        </TextBox>


                        <Label Grid.Row="1" Grid.Column="0" Content="👤 Full Name:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding CurrentCourier.NameCourier}" Style="{StaticResource emptyTextBox}"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="📱 Mobile Phone:" />
                        <TextBox Grid.Row="2" Grid.Column="1" >
                            <TextBox.Text>
                                <Binding Path="CurrentCourier.PhoneNumber" 
                                        UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <SmartInputValidator:SmartInputValidator Type="Integer"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <Label Grid.Row="3" Grid.Column="0" Content="📧 Email:" />
                        <TextBox Grid.Row="3" Grid.Column="1">
                            <TextBox.Text>
                                <Binding Path="CurrentCourier.EmailCourier" 
                                UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <SmartInputValidator:SmartInputValidator Type="Email"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>

                        <Label Grid.Row="4" Grid.Column="0" Content="🔒 Password:" />

                        <PasswordBox Grid.Row="4" Grid.Column="1" 
                        converters:PasswordBoxHelper.Attach="True"
                        converters:PasswordBoxHelper.BoundPassword="{Binding CurrentCourier.PasswordCourier, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <Label Grid.Row="5" Grid.Column="0" Content="Is Active:" />
                        <CheckBox Grid.Row="5" IsEnabled="{Binding CurrentCourier.OrderInProgress, Converter={StaticResource NotNullToBooleanFalseConverterKey}}" Grid.Column="1" IsChecked="{Binding CurrentCourier.IsActive}" Margin="5,0" VerticalAlignment="Center" />

                        <Label Grid.Row="6" Grid.Column="0" Content="Personal Max Air Distance:" />
                        <TextBox Grid.Row="6" Grid.Column="1">
                            <TextBox.Text>
                                <Binding Path="CurrentCourier.PersonalMaxAirDistance" 
                                UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <SmartInputValidator:SmartInputValidator Type="Double"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                        <Label Grid.Row="6" Grid.Column="2" Content="Km" />

                        <Label Grid.Row="7" Grid.Column="0" Content="Delivery Vehicle Type:" />
                        <ComboBox Grid.Row="7" Grid.Column="1" 
                        ItemsSource="{Binding DeliveryTypes}"
                        SelectedItem="{Binding CurrentCourier.DeliveryType, Mode=TwoWay}"
                        Margin="0,5">

                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentCourier.OrderInProgress, Converter={StaticResource NotNullToVisibilityConverterKey}}" Value="Visible">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>

                        </ComboBox>

                        <Label Grid.Row="8" Grid.Column="0" Content="📅 Start Date:" />
                        <DatePicker Grid.Row="8" Grid.Column="1" SelectedDate="{Binding CurrentCourier.StartDate}" Margin="0,5"  IsEnabled="False" />

                        <Label Grid.Row="9" Grid.Column="0" Content="Total Delivered On Time:" 
                               Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding CurrentCourier.TotalDeliveredOnTime}" 
                                   Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}"/>

                        <Label Grid.Row="10" Grid.Column="0" Content="Total Late Deliveries:" 
                               Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding CurrentCourier.TotalLateDeliveries}" 
                                   Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="3" 
                                    Orientation="Horizontal" 
                                    VerticalAlignment="Center"
                                    Margin="0,15,0,5">

                            <Label Content="Salary Details"
                                   VerticalAlignment="Center"/>
                            
                            <!--IsEnabled="{Binding IsUpdateMode}"--><!-- if we want to disable in add mode-->
                            <Button Content="Show Details" 
                                    Click="btnShowSalary_Click"
                                    
                                    FontSize="11" FontStyle="Italic" 
                                    Margin="15,0,0,0" 
                                    VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="Gray"/>
                                                <Setter Property="ToolTip" Value="Salary details are only available for existing couriers"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <StackPanel Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="3" 
                                    Orientation="Horizontal" 
                                    VerticalAlignment="Center">

                            <Label Content="Total Salary:"
                                   VerticalAlignment="Center"/>

                            <TextBlock Text="{Binding CurrentCourier.SalaryForCourier.TotalSalary, TargetNullValue=0, FallbackValue=0}" 
                                       VerticalAlignment="Center"
                                       Margin="5,0"/>

                            <Label Content="₪" 
                                   VerticalAlignment="Center"/>
                        </StackPanel>

                        <Label Grid.Row="13" Grid.Column="0" Content="📦 Order In Progress:" 
                               Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}"/>

                        <StackPanel Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="2" 
                                    Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsUpdateMode, Converter={StaticResource BoolToVis}}">

                            <TextBlock Text="{Binding CurrentCourier.OrderInProgress.ShortOrderDescription, 
                                              TargetNullValue='No active order ', 
                                              FallbackValue='No active order '}" 
                                       FontStyle="Italic"
                                       FontWeight="ExtraBold"
                                       FontSize="16" 
                                       Foreground="#FFAB91"
                                       VerticalAlignment="Center"
                                       Margin="0,0,15,0"/>
                            <Button Content="Show Order Details" 
                            Click="btnShowOrder_Click"
                            FontSize="14" 
                            FontStyle="Italic"                        
                            VerticalAlignment="Center">

                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                        <Setter Property="IsEnabled" Value="{Binding IsUpdateMode}"/>
                                        <Style.Triggers>

                                            <DataTrigger Binding="{Binding IsUpdateMode}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding CurrentCourier.OrderInProgress}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Setter Property="Background" Value="#A9A9A9"/>
                                                <Setter Property="Cursor" Value="Arrow"/>
                                                <Setter Property="ToolTip" Value="No active order to show"/>
                                            </DataTrigger>

                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"  VerticalAlignment="Bottom">
                <Button 
                    Content="{Binding ButtonText}"
                    IsDefault="True"
                       Style="{StaticResource AddButtonStyle}" Margin="0,0,8,0" Width="140" Height="45" 
                        Click="btnAddUpdate_Click"/>

                <Button Content="✖ Delete Courier" Click="btnDeleteCourier_Click" Width="140" Height="45" Margin="0,0,15,0">

                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SmallActionButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>

                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsUpdateMode}" Value="True"/>
                                        <Condition Binding="{Binding CurrentCourier, Converter={StaticResource CourierDeleteAbleToVisibilityConverterKey}}" Value="Visible"/>
                                    </MultiDataTrigger.Conditions>

                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

    </Grid>
</Window>

