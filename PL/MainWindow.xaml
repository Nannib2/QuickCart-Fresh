<Window x:Class="PL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        xmlns:converters="clr-namespace:PL.Converters"
        xmlns:SmartInputValidator="clr-namespace:PL"
        WindowState="Maximized"
        mc:Ignorable="d"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Title="Quick Cart Fresh - Management System" Height="750" Width="1100" 
         Loaded="MainWindow_Loaded" Closed="MainWindow_Closed">

   
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Grid Width="45" Height="45">
                        <Ellipse Fill="#FFAB91"/>
                        <TextBlock Text="👤" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Margin="0"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Manager" FontWeight="Bold" FontSize="16" Margin="0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="View orders" 
            Style="{StaticResource AddButtonStyle}" 
            FontWeight="ExtraBold" 
            Foreground="#555555"  
            FontSize="20" 
            Click="btnShowOrdersInList_Click"
            
            Padding="10,2" 
            Margin="5,0"/>

                    <Button Content="View Couriers" 
            Style="{StaticResource AddButtonStyle}"  
            Foreground="#555555" 
            FontWeight="ExtraBold" 
            FontSize="20" 
            Click="btnShowCouriersInList_Click"
            Padding="10,2" 
            Margin="5,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <TextBlock Text="QuickCart Fresh" VerticalAlignment="Center" FontSize="18" FontWeight="ExtraBold" Foreground="#1B5E20" Margin="0,0,10,0"/>

                    <Image Source="/Images/logoSystem.png" 
                   Height="50" 
                   VerticalAlignment="Center"
                   Margin="0,0,15,0" 
                   RenderOptions.BitmapScalingMode="HighQuality"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <Grid Margin="10,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="0.5*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📅" FontSize="18" Margin="0,0,5,0"/>
                    <TextBlock Text="System Current Time:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding CurrentTime, StringFormat='dd/MM/yyyy HH:mm'}" 
                       FontSize="16" FontWeight="Bold" Foreground="#2E7D32" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="8" Padding="8,4" BorderBrush="#A5D6A7" BorderThickness="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚀 Simulator:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="Rate: (Min)" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="12"/>

                        <TextBox Width="40" 
                         Padding="2"
                         Height="24"
                         VerticalContentAlignment="Center"
                         HorizontalContentAlignment="Center"
                         Text="{Binding SimulatorInterval, Mode=TwoWay}" 
                         IsEnabled="{Binding IsSimulatorRunning, Converter={StaticResource InverseBooleanConverterKey}}"
                         FontWeight="Bold" Margin="0,0,8,0"/>

                        <Button Click="btnToggleSimulator_Click" 
                        MinWidth="90" 
                        Padding="8,2"
                        FontSize="11"
                        Content="{Binding IsSimulatorRunning, Converter={StaticResource SimulatorStatusToTextConverterKey}}"
                        Style="{StaticResource AddButtonStyle}"
                        Background="{Binding IsSimulatorRunning, Converter={StaticResource SimulatorStatusToColorConverterKey}}"
                        Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Fast Forward:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#1B5E20" FontWeight="Bold" FontSize="12"/>
                    <StackPanel Orientation="Horizontal" IsEnabled="{Binding IsSimulatorRunning, Converter={StaticResource InverseBooleanConverterKey}}">
                        <Button Content="+Min" Style="{StaticResource AddButtonStyle}" Margin="0,0,3,0" Click="btnAddOneMinute_Click" Padding="6,3" FontSize="11"/>
                        <Button Content="+Hour" Style="{StaticResource AddButtonStyle}" Margin="0,0,3,0" Click="btnAddOneHour_Click" Padding="6,3" FontSize="11"/>
                        <Button Content="+Day" Style="{StaticResource AddButtonStyle}" Margin="0,0,3,0" Click="btnAddOneDay_Click" Padding="6,3" FontSize="11"/>
                        <Button Content="+Month" Style="{StaticResource AddButtonStyle}" Margin="0,0,3,0" Click="btnAddOneMonth_Click" Padding="6,3" FontSize="11"/>
                        <Button Content="+Year" Style="{StaticResource AddButtonStyle}" Margin="0,0,0,0" Click="btnAddOneYear_Click" Padding="6,3" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Configuration Settings" Margin="0,0,140,0" FontSize="20" FontWeight="Bold" Foreground="#1B5E20"/>
                        <Separator Width="20" Visibility="Hidden"/>
                        <Grid>
                            <Button Content="📝 Edit values" Style="{StaticResource SecondaryButtonStyle}" Margin="5,5,5,5" Visibility="{Binding IsEditingEnabled, Converter={StaticResource InverseBoolToVisConverterKey}}" IsEnabled="{Binding IsSimulatorRunning, Converter={StaticResource InverseBooleanConverterKey}}" Click="btnEditValues_Click"/>
                        <StackPanel Orientation="Horizontal" Margin="5,5,5,5">
                                <Button Content="💾 Save" Style="{StaticResource SuccessButtonStyle}" Margin="5,5,5,5" Click="btnUpdateConfig_Click" Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}" />
                                <Button Content="❌ Cancel" Style="{StaticResource DangerButtonStyle}" Margin="5,5,5,5"  Click="btnCancelChanges_Click" Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                            </Grid>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.5*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="0.5*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Content="📍 Company Address:"/>
                            <TextBox Grid.Row="0" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}" >
                                <TextBox.Text>
                                    <Binding Path="Configuration.AddressCompany" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Address"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="1" Content="Max Air Distance (Km):"/>
                            <TextBox Grid.Row="1" Grid.Column="1" IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.MaxAirDeliveryDistanceKm" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="2" Content="💰 Base Monthly Salary (₪):"/>
                            <TextBox Grid.Row="2" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.BaseSalaryMounthly" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="3" Content="Delivery Rate Per Km (₪):"/>
                            <TextBox Grid.Row="3" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.DeliveryRatePerKm" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Separator Grid.Row="4" Grid.ColumnSpan="2" Margin="0,15"/>

                            <Label Grid.Row="5" Content="🚗 Avg Speed - Car:"/>
                            <TextBox Grid.Row="5" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.AverageCarSpeedKmh" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="6" Content="🏍️ Avg Speed - Motorcycle:"/>
                            <TextBox Grid.Row="6" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.AverageMotorcycleSpeedKmh" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="7" Content="🚲 Avg Speed - Bicycle:"/>
                            <TextBox Grid.Row="7" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.AverageBicycleSpeedKmh" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="8" Content="🚶 Avg Speed - Walking:"/>
                            <TextBox Grid.Row="8" Grid.Column="1" IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.AverageWalkingSpeedKmh" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="Double"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="9" Content="⏱️ Max Delivery Time Range:"/>
                            <TextBox Grid.Row="9" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.MaxDeliveryTimeRange" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="TimeSpan"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="10" Content="⚠️ Risk Time Range:"/>
                            <TextBox Grid.Row="10" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.RiskTimeRange" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="TimeSpan"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="11" Content="Inactivity Time Range:"/>
                            <TextBox Grid.Row="11" Grid.Column="1"  IsEnabled="{Binding IsEditingEnabled}">
                                <TextBox.Text>
                                    <Binding Path="Configuration.InactivityTimeRange" UpdateSourceTrigger="PropertyChanged" >
                                        <Binding.ValidationRules>
                                            <SmartInputValidator:SmartInputValidator Type="TimeSpan"/>
                                        </Binding.ValidationRules>
                                    </Binding>
                                </TextBox.Text>
                            </TextBox>

                            <Label Grid.Row="12" Content="🔑 New Admin Password:" Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"/>
                            <PasswordBox Grid.Row="12" Grid.Column="1" Visibility="{Binding IsEditingEnabled, Converter={StaticResource BoolToVis}}"
                                         converters:PasswordBoxHelper.Attach="True"
                                         converters:PasswordBoxHelper.BoundPassword="{Binding Configuration.ManagerPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Order Summary" FontSize="20" FontWeight="Bold" Foreground="#1B5E20" Margin="0,0,0,15"/>
                    <Grid Background="#FDF8E4" Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Status" FontWeight="Bold" Padding="5"/>
                        <TextBlock Text="OnTime" Grid.Column="1" Foreground="Green" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="InRisk" Grid.Column="2" Foreground="Orange" HorizontalAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Text="Late" Grid.Column="3" Foreground="Red" HorizontalAlignment="Center" FontWeight="Bold"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding OrderSummaryDisplay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding StatusName}" VerticalAlignment="Center"/>
                                        <Button Content="{Binding OnTimeCount}" Grid.Column="1" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Click="OrderCount_Click" Tag="{Binding OnTimeTag}"/>
                                        <Button Content="{Binding InRiskCount}" Grid.Column="2" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Click="OrderCount_Click" Tag="{Binding InRiskTag}"/>
                                        <Button Content="{Binding LateCount}" Grid.Column="3" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}" Click="OrderCount_Click" Tag="{Binding LateTag}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Reset Data" Style="{StaticResource SmallActionButtonStyle}" Width="100" Height="50" Click="btnReset_Click" Margin="0,0,15,0" IsEnabled="{Binding IsSimulatorRunning, Converter={StaticResource InverseBooleanConverterKey}}"/>
                <Button Content="Initialize System" Style="{StaticResource SmallActionButtonStyle}" Width="120" Height="50" Click="btninitialization_Click" IsEnabled="{Binding IsSimulatorRunning, Converter={StaticResource InverseBooleanConverterKey}}"/>
                <TextBlock Text="© 2025 QuickCart Fresh System" VerticalAlignment="Center"  Foreground="#888888" Margin="250,0,0,0"/>
                <Separator Width="50" Visibility="Hidden"/>
            </StackPanel>
            
        </Border>
    </Grid>
</Window>