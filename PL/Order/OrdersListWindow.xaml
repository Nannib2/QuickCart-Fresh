<Window x:Class="PL.Order.OrdersListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Order"
        xmlns:converters="clr-namespace:PL.Converters"
        xmlns:enums="clr-namespace:PL.Enums"
        mc:Ignorable="d"
        WindowState="Maximized"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Title="Order Management Dashboard"
        Height="700"
        Width="1200"
        Loaded="OrderListWindow_Loaded"
        Closed="OrderListWindow_Closed">

    <Window.Resources>

        <converters:StatusToCancelVisibilityConverter x:Key="StatusToCancelVisibilityConverterKey"/>

        <CollectionViewSource x:Key="ReqCollection" Source="{Binding Source={StaticResource OrderRequirementsCollectionKey}}"/>
        <CollectionViewSource x:Key="StatusCollection" Source="{Binding Source={StaticResource OrderStatusCollectionKey}}"/>
        <CollectionViewSource x:Key="ScheduleStatusCollection" Source="{Binding Source={StaticResource ScheduleStatusCollectionKey}}"/>
        <CollectionViewSource x:Key="SortCollection" Source="{Binding Source={StaticResource OrderInListPropertiesCollectionKey}}"/>
        <converters:TimeLeftDisplayConverter x:Key="TimeLeftDisplayConverterKey"/>
        <converters:TotalTimeDisplayConverter x:Key="TotalTimeDisplayConverterKey"/>
        <converters:OrderRequirementsToImageConverter x:Key="OrderReqToImageParams"/>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1B5E20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">

            <Grid>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">

                    <Grid Width="45" Height="45">
                        <Ellipse Fill="#FFAB91"/>
                        <TextBlock Text="👤"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="20"/>
                    </Grid>

                    <StackPanel VerticalAlignment="Center"
                                Margin="10,0,0,0">
                        <TextBlock Text="Manager"
                                   FontWeight="Bold"
                                   FontSize="16"/>
                    </StackPanel>

                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <TextBlock Text="QuickCart Fresh"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="ExtraBold"
                               Foreground="#1B5E20"
                               Margin="0,0,10,0"/>

                    <Button Click="btnBackMainWindow_Click" 
                      Style="{StaticResource LogoButtonStyle}" Margin="0,0,15,0">
                        <Image Source="/Images/FinalSystemLogo.png" 
                            Height="50" 
                            VerticalAlignment="Center"
                            RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">

            <WrapPanel Orientation="Horizontal">

                <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                    <TextBlock Text="Type:" Style="{StaticResource FilterLabel}"/>
                    <ComboBox Width="120"
                              SelectedValue="{Binding SelectedOrderType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                              Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- All Types --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- All Types --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource ReqCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                    <TextBlock Text="Status:" Style="{StaticResource FilterLabel}"/>
                    <ComboBox Width="130"
                              SelectedValue="{Binding SelectedStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                              Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- All Statuses --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- All Statuses --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource StatusCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                    <TextBlock Text="Schedule Status:" Style="{StaticResource FilterLabel}"/>
                    <ComboBox Width="130"
                              SelectedValue="{Binding SelectedScheduleStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                              Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- All Schedule Statuses --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- All Schedule Statuses --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource ScheduleStatusCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                    <TextBlock Text="Sort by:" Style="{StaticResource FilterLabel}"/>
                    <ComboBox Width="140"
                              SelectedValue="{Binding SelectedSortProperty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged,
                              Converter={StaticResource SelectionToNullableConverterKey}, TargetNullValue='-- Default --'}">
                        <ComboBox.ItemsSource>
                            <CompositeCollection>
                                <sys:String>-- Default --</sys:String>
                                <CollectionContainer Collection="{Binding Source={StaticResource SortCollection}}"/>
                            </CompositeCollection>
                        </ComboBox.ItemsSource>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,20,10">
                    <TextBlock Text="Group By:" Style="{StaticResource FilterLabel}"/>
                    <ComboBox Width="120"
                              SelectedValue="{Binding SelectedGroupProperty, Mode=TwoWay}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="None" Tag="None" IsSelected="True"/>
                        <ComboBoxItem Content="Status" Tag="Status"/>
                        <ComboBoxItem Content="Order Type" Tag="OrderType"/>
                        <ComboBoxItem Content="Schedule Status" Tag="ScheduleStatus"/>
                    </ComboBox>
                </StackPanel>

            </WrapPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding OrderList}"
                  SelectedItem="{Binding SelectedOrder}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="White"
                  BorderBrush="#EEEEEE"
                  BorderThickness="1"
                  MouseDoubleClick="DataGrid_MouseDoubleClick"
                  RowStyle="{StaticResource DataGridRowOrder}"
                  RowHeaderWidth="0">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#81C784"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Border Background="#C8E6C9"
                                    Padding="10,5"
                                    CornerRadius="4"
                                    Margin="0,5,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               Foreground="#1B5E20"/>
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0} orders)'}"
                                               FontStyle="Italic"
                                               Foreground="#2E7D32"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </DataGrid.GroupStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="Icon" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Width="30" Height="30" 
                                Source="{Binding OrderType, Converter={StaticResource OrderReqToImageParams}}" 
                                RenderOptions.BitmapScalingMode="HighQuality">
                                <Image.ToolTip>
                                    <ToolTip Background="White" BorderBrush="#1B5E20" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="{Binding OrderType}" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                            <Image Width="150" Height="150"
                                   Source="{Binding OrderType, Converter={StaticResource OrderReqToImageParams}}"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Image.ToolTip>

                            </Image>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" FontWeight="Bold"/>
                <!--<DataGridTextColumn Header="Del. ID" Binding="{Binding DeliveryId, TargetNullValue='-'}"/>-->
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" FontWeight="SemiBold"/>
                <DataGridTextColumn Header="Type" Binding="{Binding OrderType}"/>
                <DataGridTextColumn Header="Dist (km)" Binding="{Binding AirDistance, StringFormat={}{0:F2}}"/>
                <DataGridTextColumn Header="Schedule" Binding="{Binding ScheduleStatus}"/>
                <DataGridTextColumn Header="Attempts" Binding="{Binding TotalDeliveries}"/>
                <DataGridTextColumn Header="Time Left" Width="*">
                    <DataGridTextColumn.Binding>
                        <Binding Converter="{StaticResource TimeLeftDisplayConverterKey}"/>
                    </DataGridTextColumn.Binding>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ScheduleStatus}" Value="Late">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>


                <DataGridTextColumn Header="Total Time" Width="*">
                    <DataGridTextColumn.Binding>
                        <Binding Converter="{StaticResource TotalTimeDisplayConverterKey}"/>
                    </DataGridTextColumn.Binding>

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Padding" Value="5"/>
                            <Setter Property="Foreground" Value="Gray"/>
                            <Setter Property="FontStyle" Value="Italic"/>
                            <Style.Triggers>
                              

                                <DataTrigger Binding="{Binding Status}" Value="Provided">
                                    <Setter Property="Foreground" Value="Black"/>
                                    <Setter Property="FontStyle" Value="Normal"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Cancel"
        Click="btnCancelOrder_Click"
        Style="{StaticResource SmallActionButtonStyle}"
        Visibility="{Binding Status, Converter={StaticResource StatusToCancelVisibilityConverterKey}}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>

        </DataGrid>

        <!-- Add Order -->
        <Button Grid.Row="3"
                Content="+ New Order"
                Click="btnAddOrder_Click"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Style="{StaticResource MainActionButtonStyle}"
                Width="160"
                Height="40"/>

    </Grid>
</Window>
