<Window x:Class="PL.Order.SelectedOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:PL.Order"
        xmlns:root="clr-namespace:PL"
        xmlns:converters="clr-namespace:PL.Converters"
        mc:Ignorable="d"
        WindowState="Maximized"
        Title="QuickCart Fresh - Select Order" Height="750" Width="1300" 
        Loaded="SelectedOrderWindow_Loaded" Closed="SelectedOrderWindow_Closed">

    <Window.Resources>
        <CollectionViewSource x:Key="OpenOrderInListPropertiesCollection" Source="{Binding Source={StaticResource OpenOrderInListPropertiesCollectionKey}}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderBorderStyle}">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Grid Width="45" Height="45">
                        <Ellipse Fill="#81C784"/>
                        <TextBlock Text="🚚" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="Available Orders" FontWeight="Bold" FontSize="18" Foreground="#1B5E20"/>
                        <TextBlock Text="Select an order to start delivery" FontSize="12" Foreground="#666666"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="QuickCart Fresh" VerticalAlignment="Center" FontSize="18" FontWeight="ExtraBold" Foreground="#1B5E20" Margin="0,0,15,0"/>
                    <Button Click="btnBack_Click" Style="{StaticResource LogoButtonStyle}" Margin="0,0,15,0">
                        <Image Source="/Images/FinalSystemLogo.png" Height="50" RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,30,0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="🔍" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Label Content="Filter by Order Type:" FontWeight="SemiBold" Foreground="#1B5E20"/>
                    </StackPanel>
                    <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" 
                             Width="200" Height="36" VerticalContentAlignment="Center" Padding="8,0"/>
                </StackPanel>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="🔃" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <Label Content="Sort By Property:" FontWeight="SemiBold" Foreground="#1B5E20"/>
                    </StackPanel>

                    <ComboBox Width="200" Height="45" VerticalContentAlignment="Center" SelectionChanged="ComboBox_SortSelectionChanged"
                              SelectedItem="{Binding SelectedSortProperty, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ItemsSource="{Binding OpenOrderInList}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Background="#FEFEFA" ClipToBounds="True" >
                <Grid>
                    <DataGrid ItemsSource="{Binding OpenOrders}" 
                              SelectedItem="{Binding SelectedOrder , Mode=TwoWay}"
                              AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE"
                              RowHeight="50" BorderThickness="0" ColumnWidth="*" Background="Transparent">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#81C784"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Padding" Value="10,12"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="🆔 ID" Binding="{Binding OrderId}" Width="Auto"/>
                            <DataGridTextColumn Header="📦 Type" Binding="{Binding OrderType}" Width="Auto"/>
                            <DataGridTextColumn Header="📍 Address" Binding="{Binding FullAddress}" Width="Auto">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextWrapping" Value="Wrap"/>
                                        <Setter Property="Padding" Value="5"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="🛍️ Items" Binding="{Binding AmountItems}" Width="Auto"/>
                            <DataGridTemplateColumn Header="🎁 Free Shipping" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsEnabled="False" IsChecked="{Binding Path=FreeShippingEligibility}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="☁️ Air Distance" Binding="{Binding AirDistance, StringFormat={}{0:N2} km}" Width="Auto"/>
                            <DataGridTextColumn Header="🛣️ Actual Distance" Binding="{Binding ActualDistance, StringFormat={}{0:N2} km}" Width="Auto"/>
                            <DataGridTextColumn Header="⏳ Delivery Time" Binding="{Binding ActualDeliveryTimeSpan, Converter={StaticResource TimeSpanToStringConverterKey}}" Width="Auto"/>
                            <DataGridTextColumn Header="⏳ Time Left" Binding="{Binding TimeToFinish, Converter={StaticResource TimeSpanToStringConverterKey}}" Width="Auto"/>
                            <DataGridTextColumn Header="🛍️ Status" Binding="{Binding ScheduleStatus}" Width="Auto"/>
                            <DataGridTemplateColumn Header="⚡ Action" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Collect" 
                                                Command="{Binding DataContext.CollectOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SuccessButtonStyle}"
                                                Padding="12,5" RenderTransformOrigin="0.5,0.5">
                                            <Button.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Button.RenderTransform>
                                            <Button.Triggers>
                                                <EventTrigger RoutedEvent="Button.Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.1" AutoReverse="True"/>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.1" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Button.Triggers>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding OpenOrders, Converter={StaticResource CollectionEmptyToVisibilityConverter}}">
                        <TextBlock Text="🔍" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding FilterText, Converter={StaticResource FilterTextToMessageConverterKey}}"
                           FontSize="16" Foreground="Gray" FontWeight="Medium"
                           HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="12" Effect="{StaticResource CardShadow}" 
                    BorderBrush="#DDD" BorderThickness="1" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="15">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🌐" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Live OpenStreetMap" FontWeight="Bold" FontSize="14" Foreground="#1B5E20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" ClipToBounds="True">
                        <WebBrowser root:BrowserBehavior.Html="{Binding MapHtml}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"/>

                        <Grid Visibility="{Binding IsOrderSelected, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" 
                              Background="#F9F9F9">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🗺️" FontSize="40" HorizontalAlignment="Center" Opacity="0.5"/>
                                <TextBlock Text="Select an order to view route" 
                                           Foreground="#999" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2" Background="#FAFAFA" Padding="10">
                        <StackPanel Orientation="Vertical">

                            <Button Content="🌍 Open in Google Maps (External)" 
                                    Click="OpenInGoogleMaps_Click"
                                    Visibility="{Binding IsOrderSelected, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource LogoButtonStyle}"
                                    HorizontalAlignment="Center"
                                    FontSize="12" Margin="0,0,0,10" Cursor="Hand"/>

                            <Border BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Margin="10,0,10,10" 
                                    Visibility="{Binding IsOrderSelected, Converter={StaticResource BoolToVis}}"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="#2196F3" Margin="0,0,5,0"/>
                                <TextBlock Text="Route" FontSize="11" Foreground="#666" Margin="0,0,15,0"/>

                                <Grid Margin="0,0,5,0" VerticalAlignment="Center" Width="20">
                                    <Line X1="0" Y1="0" X2="20" Y2="0" Stroke="#FF5722" StrokeThickness="2" StrokeDashArray="2 2"/>
                                </Grid>
                                <TextBlock Text="Air Dist." FontSize="11" Foreground="#666"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>