<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:BO="clr-namespace:BO;assembly=BL">

    <!-- ================= COLORS ================= -->

    <Color x:Key="PrimaryColor">#B3E5FC</Color>
    <Color x:Key="SecondaryColor">#FFCC80</Color>
    <Color x:Key="AccentColor">#A5D6A7</Color>
    <Color x:Key="DangerColor">#FFAB91</Color>

    <Color x:Key="TextColor">#2D3748</Color>
    <Color x:Key="BorderColor">#FDF8E4</Color>
    <Color x:Key="BackgroundColor">#FAFAFA</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>

    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <DropShadowEffect x:Key="CardShadow" ShadowDepth="1" Direction="270" Color="#AAAAAA" Opacity="0.3" BlurRadius="12"/>

    <!-- ================= WINDOW and BORDER ================= -->

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="HeaderBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BorderBrushSoft}"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="20,10"/>
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BorderBrushSoft }"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Margin" Value="10,10,10,10"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect" Value="{StaticResource CardShadow}"/>
    </Style>

    <!-- ================= TEXT ================= -->

    <!-- Implicit -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,20"/>
    </Style>

    <!-- ================= INPUTS ================= -->

    <Style x:Key="BaseInputStyle" TargetType="Control">
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,6"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
        <Setter Property="Background" Value="White"/>
    </Style>


    <Style TargetType="PasswordBox" BasedOn="{StaticResource BaseInputStyle}"/>
    <Style TargetType="ComboBox" BasedOn="{StaticResource BaseInputStyle}"/>
    <Style TargetType="DatePicker" BasedOn="{StaticResource BaseInputStyle}"/>

    <!--empty TextBox-->
    <Style x:Key="emptyTextBox"
           TargetType="TextBox"
           BasedOn="{StaticResource BaseInputStyle}">
        <Style.Triggers>
            <Trigger Property="Text" Value="">
                <Setter Property="Background" Value="#FFF5F5"/>
                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!--TextBox style with validation error-->
    <Style TargetType="TextBox" BasedOn="{StaticResource BaseInputStyle}">
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="true">

                <Setter Property="Background" Value="#FFF2F2"/>

                <Setter Property="BorderBrush" Value="Red"/>
                <Setter Property="BorderThickness" Value="1"/>

                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                Path=(Validation.Errors)[0].ErrorContent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <Style x:Key="ModernComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="#F5F5F5"/>
        <Setter Property="BorderBrush" Value="#81C784"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="4,3"/>
        <Setter Property="FontSize" Value="13"/>

        <Style.Resources>
            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="White" />
            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#81C784" />
        </Style.Resources>
    </Style>


    <!--Style of Border For input (for login) -->
    <Style x:Key="ModernInputBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="BorderBrush" Value="#A68946"/>
        <Setter Property="Padding" Value="12,10"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#6D4C41"/>
            </Trigger>
            <!-- focus -->
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsKeyboardFocusWithin}" Value="True">
                <Setter Property="BorderBrush" Value="#1B5E20"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#1B5E20" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Style to Text Box Into Border (for login)-->
    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="#333333"/>
    </Style>

    <!-- Style to password box into border (for login)-->
    <Style x:Key="ModernPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="Foreground" Value="#333333"/>
    </Style>

    <!-- icons (for login) -->
    <Style x:Key="InputIconStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
        <Setter Property="Opacity" Value="0.6"/>
    </Style>

    <!-- ================= BUTTON TEMPLATE ================= -->

    <ControlTemplate x:Key="RoundedButtonTemplate" TargetType="Button">
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <ContentPresenter
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="12,6"/>
        </Border>
    </ControlTemplate>

    <!-- ================= BUTTONS ================= -->

    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Template" Value="{StaticResource RoundedButtonTemplate}"/>
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>

        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#90CAF9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--1 Button Styles Based on BaseButtonStyle-->
    <Style x:Key="PrimaryButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource BaseButtonStyle}"/>

    <!--2 Button Styles Based on BaseButtonStyle-->
    <Style x:Key="SecondaryButtonStyle"
   TargetType="Button"
   BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource SecondaryBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FFE0B2"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!--3 Button Styles Based on BaseButtonStyle-->
    <Style x:Key="DangerButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#FFE0B2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--4 Button Styles Based on BaseButtonStyle-->
    <Style x:Key="SuccessButtonStyle"
        TargetType="Button"
        BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#81C784"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--5 Button Styles Based on BaseButtonStyle, add clock, add/update courier or order-->
    <Style x:Key="AddButtonStyle"
    TargetType="Button"
    BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="#F9FBE7"/>
        <Setter Property="BorderThickness" Value="5"/>
        <Setter Property="BorderBrush" Value="#1B5E20"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#C8E6C9"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!--Logo Button Style-->
    <Style x:Key="LogoButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="5"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter Property="Background" Value="#10000000"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.7"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--another button style for listes windows-->
    <Style x:Key="MainActionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#81C784"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                      CornerRadius="22"
                      Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#66BB6A"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!--Button style for small action buttons (Delete, cancel, reset, intInitializtion)-->
    <Style x:Key="SmallActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Width" Value="65"/>
        <Setter Property="Height" Value="25"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Background" Value="#FDECEA"/>
        <Setter Property="Foreground" Value="#C62828"/>
        <Setter Property="BorderBrush" Value="#C62828"/>
        <Setter Property="Template">

            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E57373"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    <!-- ================= DATAGRID ================= -->

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowHeight" Value="36"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="#EEEEEE"/>
        <Setter Property="SelectionUnit" Value="FullRow"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#81C784"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="10,6"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Grid Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="DataGridRowOrder" TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
        <Style.Triggers>

            <DataTrigger Binding="{Binding ScheduleStatus}"
                         Value="{x:Static BO:ScheduleStatus.InRisk}">
                <Setter Property="Background" Value="#FFF5F5"/>
                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>

            <DataTrigger Binding="{Binding Status}" Value="Canceled">
                <Setter Property="Background" Value="#FFF0F0"/>
                <Setter Property="Foreground" Value="#9E9E9E"/>
                <Setter Property="TextBlock.TextDecorations" Value="Strikethrough"/>
                <Setter Property="FontStyle" Value="Italic"/>
            </DataTrigger>



            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#F1F5F9"/>
            </Trigger>

            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#E2E8F0"/>
                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
            </Trigger>

        </Style.Triggers>
    </Style>

    <!-- ================= STATUS ================= -->

    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="MinWidth" Value="110"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Background" Value="#E2E8F0"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.Supplied}">
                <Setter Property="Background" Value="#D1FAE5"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.Canceled}">
                <Setter Property="Background" Value="#FEE2E2"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.CustomerRefused}">
                <Setter Property="Background" Value="#FEF3C7"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.Failed}">
                <Setter Property="Background" Value="#FCA5A5"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusIconStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,5,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.Supplied}">
                <Setter Property="Text" Value="✓"/>
                <Setter Property="Foreground" Value="#065F46"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.Canceled}">
                <Setter Property="Text" Value="✕"/>
                <Setter Property="Foreground" Value="#991B1B"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding DeliveryCompletionType}"
                         Value="{x:Static BO:DeliveryCompletionType.Failed}">
                <Setter Property="Text" Value="⚠"/>
                <Setter Property="Foreground" Value="#7F1D1D"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="#2D3748"/>
    </Style>









</ResourceDictionary>