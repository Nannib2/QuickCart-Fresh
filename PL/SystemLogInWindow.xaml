<Window x:Class="PL.SystemLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        xmlns:converters="clr-namespace:PL.Converters"
        Icon="/Images/LogoForTaskbar.ico"
        mc:Ignorable="d"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Title="System Login" 
        Width="488" 
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Height="640">

    <Border Style="{StaticResource CardBorderStyle}" 
        Margin="25,25,25,35">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Logo section with decorative icons on separator line -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,10,0,20">
                <!-- Company logo image -->
                <Image Source="/Images/FinalSystemLogo.png"
                           Width="160"
                           Height="160"
                           Stretch="Uniform"
                           Margin="0,0,0,15"/>

                <!-- Separator line with decorative icons -->
                <Grid Width="240" Height="45">
                    <!-- Horizontal separator line -->
                    <Border Height="3" 
                                Background="#1B5E20"
                                CornerRadius="2"
                                VerticalAlignment="Center"
                                Opacity="0.6"/>

                    <!-- Icons positioned on the separator line -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left icon - Shopping cart -->
                        <Border Grid.Column="0"
                                    Background="White"
                                    CornerRadius="22"
                                    Width="44" 
                                    Height="44"
                                    BorderThickness="2.5"
                                    BorderBrush="#1B5E20"
                                    HorizontalAlignment="Right"
                                    Margin="0,0,8,0"
                                    Cursor="Hand"
                                    RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect Color="#1B5E20" 
                                                    BlurRadius="8" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.3"/>
                            </Border.Effect>
                            <!-- Hover animation style -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <!-- Trigger when mouse enters -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <!-- Scale up animation on hover -->
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                           To="1.2" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                           To="1.2" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <!-- Scale back to normal when mouse leaves -->
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                           To="1" Duration="0:0:0.2"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                           To="1" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🛒" 
                                           FontSize="23"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>

                        <!-- Right icon - Delivery truck -->
                        <Border Grid.Column="1"
                                    Background="White"
                                    CornerRadius="22"
                                    Width="44" 
                                    Height="44"
                                    BorderThickness="2.5"
                                    BorderBrush="#1B5E20"
                                    HorizontalAlignment="Left"
                                    Margin="8,0,0,0"
                                    Cursor="Hand"
                                    RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Effect>
                                <DropShadowEffect Color="#1B5E20" 
                                                    BlurRadius="8" 
                                                    ShadowDepth="0" 
                                                    Opacity="0.3"/>
                            </Border.Effect>
                            <!-- Hover animation style -->
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <!-- Trigger when mouse enters -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <!-- Scale up animation on hover -->
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                           To="1.2" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                           To="1.2" Duration="0:0:0.2">
                                                            <DoubleAnimation.EasingFunction>
                                                                <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <!-- Scale back to normal when mouse leaves -->
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                           To="1" Duration="0:0:0.2"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                           To="1" Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="🚚" 
                                           FontSize="23"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Grid>
            </StackPanel>

            <!-- Input fields section -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <!-- User ID input field -->
                <Label Content="User ID" FontStyle="Oblique"/>

                <Border Style="{StaticResource ModernInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- User icon -->
                        <TextBlock Text="👤" Style="{StaticResource InputIconStyle}"/>

                        <!-- User ID text input -->
                        <TextBox Grid.Column="1"
                                     Text="{Binding EnteredId, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     MaxLength="9"/>
                    </Grid>
                </Border>

                <!-- Password input field -->
                <Label Content="Password" FontStyle="Oblique" Margin="0,15,0,0"/>

                <Border Style="{StaticResource ModernInputBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Lock icon -->
                        <TextBlock Text="🔒" Style="{StaticResource InputIconStyle}"/>

                        <!-- Password input box -->
                        <PasswordBox Grid.Column="1"
                                         Style="{StaticResource ModernPasswordBoxStyle}"
                                         converters:PasswordBoxHelper.Attach="True"
                                         converters:PasswordBoxHelper.BoundPassword="{Binding EnteredPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Login button section -->
            <StackPanel Grid.Row="2" Margin="0,30,0,0">
                <Button Content="Login" 
                            IsDefault="True"
                            Click="BtnLogin_Click"
                            Style="{StaticResource AddButtonStyle}"
                            Width="100"
                            BorderThickness="20"
                            FontSize="16" FontWeight="Bold"
                            Foreground="White">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="22"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>